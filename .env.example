# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/rippl
DB_USERNAME=rippl
DB_PASSWORD=rippl

# JWT
JWT_SECRET=change-me-min-32-chars-long-for-hmac-signing

# Resend (magic link emails)
# Get your API key at https://resend.com
# Use "re_test" to skip email sending in dev
RESEND_API_KEY=re_test

# URLs
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# Chrome Extension ID
EXTENSION_ID=dev-extension-id
