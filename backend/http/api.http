### Variables
@host = http://localhost:8080
@email = moko@example.com
@ingestToken = PASTE_INGEST_TOKEN_HERE

### ============================================
### AUTH
### ============================================

### Send magic link
POST {{host}}/api/auth/magic-link
Content-Type: application/json

{"email": "{{email}}"}

### Verify magic link (paste token from DB or logs)
# @name verify
GET {{host}}/api/auth/verify?token=eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJtb2tvQGV4YW1wbGUuY29tIiwianRpIjoiNmU0MDRhM2ItZjg4OS00MmRlLWI1NjUtNTkxNjBkMWRiNmZkIiwiaWF0IjoxNzc3ODMzOTQ0LCJleHAiOjE3Nzc4MzQ4NDR9.p6cGD_bWdjy8Mawt_diYbACjcaJOSPPtdOXJKkuHavI

### Get current user (needs session cookie from verify response)
GET {{host}}/api/auth/me
Cookie: session={{verify.response.headers.Set-Cookie}}

### Logout
POST {{host}}/api/auth/logout
Cookie: session={{verify.response.headers.Set-Cookie}}

### ============================================
### SYNC (Bearer ingest token required)
### ============================================

### Create Chrome extension collector (returns token)
# @name createCollector
POST {{host}}/api/collectors
Content-Type: application/json
Cookie: session={{verify.response.headers.Set-Cookie}}

{"type": "chrome_extension"}

### Copy token from createCollector response body into @ingestToken above

### Sync sessions
POST {{host}}/api/sync/sessions
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "sessions": [
    {
      "id": "sess-1714700000000-a3f8k2",
      "domain": "claude.ai",
      "startedAt": 1714700000000,
      "endedAt": 1714700720000,
      "activeSeconds": 680,
      "date": "2026-05-03",
      "activityType": "coding",
      "estimatedWithoutMinutes": 30,
      "timeSavedMinutes": 19,
      "logged": true
    },
    {
      "id": "sess-1714700100000-b4g9l3",
      "domain": "chatgpt.com",
      "startedAt": 1714700100000,
      "endedAt": 1714700400000,
      "activeSeconds": 280,
      "date": "2026-05-03",
      "activityType": "writing",
      "estimatedWithoutMinutes": 15,
      "timeSavedMinutes": 10
    }
  ]
}

### Sync duplicate (should return accepted=0, duplicates=1)
POST {{host}}/api/sync/sessions
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "sessions": [
    {
      "id": "sess-1714700000000-a3f8k2",
      "domain": "claude.ai",
      "startedAt": 1714700000000,
      "endedAt": 1714700720000,
      "activeSeconds": 680,
      "date": "2026-05-03"
    }
  ]
}

### ============================================
### INGESTION V1 (Bearer ingest token required)
### ============================================

### Ingest activity session (first write => 201)
# @name ingestSession
POST {{host}}/v1/activity-sessions
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "collector": {
    "type": "chrome_extension",
    "version": "1.0.0"
  },
  "source": {
    "type": "browser",
    "version": "126"
  },
  "session": {
    "id": "sess-http-v1-dedupe",
    "started_at": 1714700000000,
    "ended_at": 1714700720000
  },
  "privacy": {
    "content_collected": false,
    "content_sent": false,
    "prompt_collected": false,
    "response_collected": false
  },
  "metrics": {
    "sample_metric": 1,
    "copy_events": 2
  },
  "context": {
    "domain": "claude.ai",
    "mode": "manual-http"
  }
}

### Ingest duplicate (same session.id => 200 deduped=true)
POST {{host}}/v1/activity-sessions
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "collector": {
    "type": "chrome_extension",
    "version": "1.0.0"
  },
  "source": {
    "type": "browser",
    "version": "126"
  },
  "session": {
    "id": "sess-http-v1-dedupe",
    "started_at": 1714700000000,
    "ended_at": 1714700720000
  },
  "privacy": {
    "content_collected": false,
    "content_sent": false,
    "prompt_collected": false,
    "response_collected": false
  },
  "metrics": {
    "sample_metric": 999
  },
  "context": {
    "domain": "claude.ai"
  }
}

### Submit task_type feedback (upsert by type)
POST {{host}}/v1/activity-sessions/{{ingestSession.response.body.$.session_id}}/feedback
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "type": "task_type",
  "value": "coding"
}

### Submit accuracy feedback (same session)
POST {{host}}/v1/activity-sessions/{{ingestSession.response.body.$.session_id}}/feedback
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "type": "accuracy",
  "value": 0.9
}

### Ingest policy violation example (should return 400 policy_violation)
POST {{host}}/v1/activity-sessions
Content-Type: application/json
Authorization: Bearer {{ingestToken}}

{
  "collector": {
    "type": "chrome_extension",
    "version": "1.0.0"
  },
  "source": {
    "type": "browser",
    "version": "126"
  },
  "session": {
    "id": "sess-http-v1-policy",
    "started_at": 1714700000000,
    "ended_at": 1714700720000
  },
  "privacy": {
    "content_collected": true,
    "content_sent": false,
    "prompt_collected": false,
    "response_collected": false
  },
  "metrics": {},
  "context": {}
}

### ============================================
### TRENDS
### ============================================

### Weekly trends
GET {{host}}/api/trends/weekly
Cookie: session={{verify.response.headers.Set-Cookie}}

### Weekly trends with date range
GET {{host}}/api/trends/weekly?from=2026-04-01&to=2026-05-31
Cookie: session={{verify.response.headers.Set-Cookie}}

### Monthly trends
GET {{host}}/api/trends/monthly
Cookie: session={{verify.response.headers.Set-Cookie}}

### Time saved
GET {{host}}/api/trends/time-saved
Cookie: session={{verify.response.headers.Set-Cookie}}

### ============================================
### INSIGHTS
### ============================================

### Mirror moments
GET {{host}}/api/insights/mirror
Cookie: session={{verify.response.headers.Set-Cookie}}

### ============================================
### COLLECTORS
### ============================================

### List collectors
GET {{host}}/api/collectors
Cookie: session={{verify.response.headers.Set-Cookie}}

### Add Chrome extension collector
POST {{host}}/api/collectors
Content-Type: application/json
Cookie: session={{verify.response.headers.Set-Cookie}}

{"type": "chrome_extension"}

### Remove collector (paste ID)
DELETE {{host}}/api/collectors/PASTE_COLLECTOR_ID_HERE
Cookie: session={{verify.response.headers.Set-Cookie}}

### ============================================
### ACCOUNT
### ============================================

### Delete account (DESTRUCTIVE - deletes user + all data)
DELETE {{host}}/api/account
Cookie: session={{verify.response.headers.Set-Cookie}}

### ============================================
### DEV HELPER: Get session token directly
### Since magic link emails are skipped in dev,
### use this to get a session cookie manually.
###
### 1. Run "Send magic link" above
### 2. Query the auth_tokens table:
###    SELECT token_hash FROM auth_tokens ORDER BY expires_at DESC LIMIT 1;
### 3. Or add a log line in AuthService to print the verify link
### ============================================
